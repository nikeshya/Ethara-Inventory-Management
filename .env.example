# Application Settings
APP_NAME="Ethara AI - Inventory & Order Management"
APP_VERSION="1.0.0"
DEBUG=True

# Database Configuration
# Local PostgreSQL
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/inventory_db"
# Docker PostgreSQL (uncomment when using docker-compose)
# DATABASE_URL="postgresql://postgres:postgres@postgres:5432/inventory_db"

# CORS Configuration
# Comma-separated list of allowed origins (JSON array format)
CORS_ORIGINS=["http://localhost:3000", "http://localhost:5173", "http://127.0.0.1:3000"]
